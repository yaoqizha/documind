# ── LLM API Keys (填你要用的供應商即可) ───────────────────
# Google Gemini（免費額度友善，於 https://aistudio.google.com/apikey 申請）
GOOGLE_API_KEY=AIza...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Model settings ───────────────────────────────────────────
# 生成模型供應商：google | anthropic | openai
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash-lite  # google: gemini-2.5-flash-lite（免費額度最高，適合 demo）
                                 # 註：gemini-2.5-flash 免費層每日僅 20 次請求，2.0 系列為 0
                                 # anthropic: claude-sonnet-4-6 | openai: gpt-4o-mini

# Embedding 供應商：google | openai（Anthropic 無 embedding API）
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=models/gemini-embedding-001   # google（降維至 768）/ openai=text-embedding-3-small(1536)
# 向量維度必須與 embedding 模型一致：Google 降維後=768, OpenAI=1536
EMBEDDING_DIM=768

# ── Database ─────────────────────────────────────────────────
# 本地開發直接用這個（配合 docker-compose）
DATABASE_URL=postgresql://documind:documind_pass@localhost:5432/documind

# ── App settings ─────────────────────────────────────────────
APP_ENV=development              # development | production
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVER_TOP_K=10              # 語意檢索取幾個候選
RERANKER_TOP_N=3                # Reranker 最後留幾個
